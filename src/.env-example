# -----------------------------------------------
# Agent 运行参数
# -----------------------------------------------
# 最大 LLM 调用轮数（默认 40）
MAX_LLM_CALL_PER_RUN=50

# 网页内容最大长度，单位字节（默认 200000）
WEBCONTENT_MAXLENGTH=200000

# Agent 同时执行的最大任务数（默认 1，竞赛推荐使用 1）
MAX_WORKERS=5

# ============================================================
# 阿里百炼（DashScope）API 配置
# ============================================================
DASHSCOPE_API_KEY=xxx

# -----------------------------------------------
# 工具 API Key
# -----------------------------------------------
# Google 搜索（Serper API）
GOOGLE_SEARCH_KEY=xxx

# 网页抓取（Jina Reader API）
JINA_API_KEY=xxx

# -----------------------------------------------
# 模型选择（可选，以下为默认值，按需修改）
# -----------------------------------------------
# 主模型：Agent 推理时使用
DASHSCOPE_MAIN_MODEL=qwen3-max

# 摘要模型：tool_visit.py 中网页内容提取时使用
DASHSCOPE_SUMMARY_MODEL=qwen3.5-plus

# 问题分解器模型（两步：分解 + 校验）
DECOMPOSER_MODEL=qwen3.5-plus    # Step 1: 分解（能力强）
CHECKER_MODEL=qwen3.5-plus      # Step 2: 校验/精炼（速度快）

# 搜索黑板摘要模型（每3次工具调用触发一次）
SCRATCHPAD_MODEL=qwen3.5-plus

# -----------------------------------------------
# 思考模式（Thinking Mode）,主 Agent 不推荐开启
# -----------------------------------------------
ENABLE_THINKING=false
