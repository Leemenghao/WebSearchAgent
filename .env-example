# ============================================================
# 阿里百炼（DashScope）API 配置
# 请将下方 sk-xxxx 替换为你的真实 API Key
# ============================================================
DASHSCOPE_API_KEY=xxx

# -----------------------------------------------
# 模型选择（可选，以下为默认值，按需修改）
# -----------------------------------------------
# 主模型：Agent 推理时使用（通过 --model 参数传入，此处仅作备注）
# 可用模型示例：qwen-max, qwen-plus, qwen-turbo
# 支持思考模式的模型示例：qwen3-235b-a22b, qwen3-30b-a3b
DASHSCOPE_MAIN_MODEL=qwen3-max

# 摘要模型：tool_visit.py 中网页内容提取时使用
DASHSCOPE_SUMMARY_MODEL=qwen3-max

# 评估模型：evaluate.py 中答案评判时使用
DASHSCOPE_JUDGE_MODEL=qwen3-max

# -----------------------------------------------
# 思考模式（Thinking Mode）
# -----------------------------------------------
# 设置为 true 以启用流式思考（需要模型支持，如 qwen3 系列）
# 设置为 false 使用普通模式（默认，适用于所有模型）
ENABLE_THINKING=false

# -----------------------------------------------
# 工具 API Key
# -----------------------------------------------
# Google 搜索（Serper API）
GOOGLE_SEARCH_KEY=xxx

# 网页抓取（Jina Reader API）
JINA_API_KEY=xxx

# -----------------------------------------------
# Agent 运行参数（可选）
# -----------------------------------------------
# 最大 LLM 调用轮数（默认 40）
MAX_LLM_CALL_PER_RUN=40

# 网页内容最大长度，单位字节（默认 150000）
WEBCONTENT_MAXLENGTH=150000
